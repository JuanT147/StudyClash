# MONGODB_URI: Mongo Atlas connection string used by the backend.
MONGODB_URI="your-key"

# GEMINI_API_KEY: Gemini API key used only on the backend.
GEMINI_API_KEY="your-gemini-api-key"

# VITE_API_BASE_URL: Base URL for the backend API used by the React app.
VITE_API_BASE_URL="http://localhost:4001"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000/"


PORT="4001"
